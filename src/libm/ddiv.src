	.assume	adl=1

	.section	.text

	.global	__ddiv
	.type	__ddiv, @function

; long double __ddiv_c(long double const *__restrict y, long double x)
__ddiv:
	push	iy
	push	af

	push	bc
	push	de
	push	hl
	ld	hl, 18
	add	hl, sp
	push	hl
	call	___ddiv_c
	pop	af
	pop	af
	pop	af
	pop	af

	pop	af
	pop	iy
	ret

	.extern	___ddiv_c
