	.assume	adl=1

	.section	.text

	.global	__lsubs_sat
	.type	__lsubs_sat, @function

__lsubs_sat:
	; signed saturated subtraction
	; E:UHL = E:UHL - A:UBC
	call	__lsubs_overflow
	ret	po
	sla	e
	sbc	hl, hl
	ld	e, $80
	ret	nc		; negative underflow
	; positive overflow
	dec	e
	ret

	.extern	__lsubs_overflow
