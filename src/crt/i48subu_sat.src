	.assume	adl=1

	.section	.text

	.global	__i48subu_sat
	.type	__i48subu_sat, @function

__i48subu_sat:
	; unsigned saturated subtraction
	; UDE:UHL = UDE:UHL - UIY:UBC
	or	a, a
	sbc	hl, bc
	ex	de, hl
	push	bc
	lea	bc, iy + 0
	sbc	hl, bc
	pop	bc
	ex	de, hl
	ret	nc
	or	a, a
	sbc	hl, hl
	ex	de, hl
	sbc	hl, hl
	ret
