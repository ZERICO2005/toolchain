	.assume	adl=1

	.section	.text
	.global	__bshl
	.type	__bshl, @function

.ifdef PREFER_OS_CRT

	.set	__bshl, 0x000100

.else

__bshl:
; A = A << B
; CC: 19 bytes + (ADL ? 3R : 2R)
; 0: 14F + 4
; 1: 16F + 4
; 2: 15F + 3
; 3: 17F + 3
; 4: 17F + 3
; 5: 19F + 3
; 6: 18F + 2
; 7: 20F + 2
	bit	2, b
	jr	z, .L.bit2
	add	a, a
	add	a, a
	add	a, a
	add	a, a
.L.bit2:
	bit	1, b
	jr	z, .L.bit1
	add	a, a
	add	a, a
.L.bit1:
	bit	0, b
	ret	z
	add	a, a
	ret

.endif
