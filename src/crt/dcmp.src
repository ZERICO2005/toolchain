	ld	c, a
	ld	b, (iy - 2)	; bit 7 of b = sign of x
	ld	a, 2	; non zero
	or	a, b
	add	a, 0	; reset PE
	ld	a, c
.finish_zero:
	pop	hl
	pop	bc
	pop	iy
	ret

