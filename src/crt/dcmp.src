	cpl
	xor	a, (iy - 2)	; bit 7 of B = sign of x
	or	a, 2	; set S flag, ensure that A cannot be zero
	add	a, 0	; reset PE
	ld	c, a
.equal:
	pop	hl
	pop	bc
	pop	iy
