.different_sign:
	; test for zero
	push	bc
	res	7, b
	srl	h	; undo rlc
	call	.zero_test	; returns if x and y are not zero

	ld	b, (iy - 5)
	rlc	b
	sbc	hl, hl
	set	0, h	; hl is now -1 or +1
	add	hl, bc
	or	a, a
	sbc	hl, bc

	pop	bc
	pop	hl
.finish_zero:
	pop	iy
	ret

.zero_test:
	; x[hi-md-lo]
	; y[hi-md-lo]
	add.s	hl, bc
	adc	hl, de
	ret	nz
	ret	c
	; x[00-00-lo]
	; y[00-md-lo]
	; HL is zero, Carry is reset
	ld	hl, (iy + 6)	; y.lo
	ld	bc, (iy + 9)	; y.md
	add	hl, bc
	ld	bc, (iy - 3)	; x.lo
	adc	hl, bc
	ret	nz
	ret	c
	; Z, NC, and P
	pop	bc	; zero_test return address
	pop	bc
	pop	hl
	pop	iy
	ret

