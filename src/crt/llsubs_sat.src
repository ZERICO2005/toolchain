	.assume	adl=1

	.section	.text

	.global	__llsubs_sat
	.type	__llsubs_sat, @function

__llsubs_sat:
	; signed saturated subtraction
	; BC:UDE:UHL = BC:UDE:UHL - (SP)
	call	__llsubs_overflow
	ret	po
	sla	b
	sbc	hl, hl
	ex	de, hl
	sbc	hl, hl
	ld	c, l
	ld	b, $80
	ret	nc		; negative underflow
	; positive overflow
	dec	b
	ret

	.extern	__llsubs_overflow
