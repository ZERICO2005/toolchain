	.assume	adl=1

	.section	.text
	.global	__bshru
	.type	__bshru, @function

.ifdef PREFER_OS_CRT

	.set	__bshru, 0x000104

.else

__bshru:
; A = (unsigned)A >> B
; CC: 24 bytes + (ADL ? 3R : 2R)
; 0: 14F + 4
; 1: 17F + 4
; 2: 17F + 3
; 3: 20F + 3
; 4: 19F + 3
; 5: 22F + 3
; 6: 22F + 2
; 7: 25F + 2
	bit	2, b
	jr	z, .L.bit2
	rrca
	rrca
	rrca
	rrca
	and	a, $0F
.L.bit2:
	bit	1, b
	jr	z, .L.bit1
	srl	a
	srl	a
.L.bit1:
	bit	0, b
	ret	z
	srl	a
	ret

.endif
