	.assume	adl=1

	.section	.text

	.global	__ladds_sat
	.type	__ladds_sat, @function

__ladds_sat:
	; signed saturated addition
	; E:UHL = E:UHL + A:UBC
	push	bc
	add	hl, bc
	ld	c, a
	adc	a, e
	ld	e, a
	ld	a, c
	pop	bc
	ret	po
	ld	e, $7F
	ld	hl, $FFFFFF
	ret	m		; positive overflow
	; negative underflow
	inc	hl
	inc	e
	ret
