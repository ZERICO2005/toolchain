// -*- C++ -*-
#ifndef _EZCXX_CXX_STREAM
#define _EZCXX_CXX_STREAM

#include <cstddef>
#include <cstdio>
#include <string>
#include <ti/sprintf.h>

#pragma clang system_header

namespace std {

class ostream {
public:
};

static ostream cout;
static ostream cerr;
static ostream clog;

constexpr char endl = '\n';
constexpr char ends = '\0';

class istream {
    public:

    inline void get(char & c){ c = getchar(); }
    inline char get(){ char c; c = getchar(); return c;}
};

static istream cin;

inline ostream& operator<<(ostream& os, const std::string& str) {
    std::fputs(str.c_str(), stdout);
    return os;
}
inline ostream& operator<<(ostream& os, const char* str) {
    std::fputs(str, stdout);
    return os;
}
inline ostream& operator<<(ostream& os, bool value) {
    std::fputc((value ? '1' : '0'), stdout);
    return os;
}
inline ostream& operator<<(ostream& os, char value) {
    std::fputc(value, stdout);
    return os;
}
inline ostream& operator<<(ostream& os, unsigned char value) {
    std::fputc(value, stdout);
    return os;
}

inline ostream& operator<<(ostream& os, const void* ptr) {
    char buf[sizeof("000000")];
    boot_sprintf(buf, "%p", ptr);
    std::fputs(buf, stdout);
    return os;
}
inline ostream& operator<<(ostream& os, const volatile void* ptr) {
    char buf[sizeof("000000")];
    boot_sprintf(buf, "%p", ptr);
    std::fputs(buf, stdout);
    return os;
}
inline ostream& operator<<(ostream& os, nullptr_t) {
    std::fputs("000000", stdout);
    return os;
}

inline ostream& operator<<(ostream& os, short value) {
    char buf[sizeof("-32768")];
    boot_sprintf(buf, "%d", value);
    std::fputs(buf, stdout);
    return os;
}
inline ostream& operator<<(ostream& os, unsigned short value) {
    char buf[sizeof("65535")];
    boot_sprintf(buf, "%u", value);
    std::fputs(buf, stdout);
    return os;
}
inline ostream& operator<<(ostream& os, int value) {
    char buf[sizeof("-8388608")];
    boot_sprintf(buf, "%d", value);
    std::fputs(buf, stdout);
    return os;
}
inline ostream& operator<<(ostream& os, unsigned int value) {
    char buf[sizeof("16777215")];
    boot_sprintf(buf, "%u", value);
    std::fputs(buf, stdout);
    return os;
}

inline ostream& operator<<(ostream& os, long value) {
    std::printf("%ld", value);
    return os;
}
inline ostream& operator<<(ostream& os, unsigned long value) {
    std::printf("%lu", value);
    return os;
}
inline ostream& operator<<(ostream& os, signed __int48 value) {
    std::printf("%lld", static_cast<signed long long>(value));
    return os;
}
inline ostream& operator<<(ostream& os, unsigned __int48 value) {
    std::printf("%llu", static_cast<unsigned long long>(value));
    return os;
}
inline ostream& operator<<(ostream& os, long long value) {
    std::printf("%lld", value);
    return os;
}
inline ostream& operator<<(ostream& os, unsigned long long value) {
    std::printf("%llu", value);
    return os;
}

inline ostream& operator<<(ostream& os, float value) {
    printf("%f", value);
    return os;
}
inline ostream& operator<<(ostream& os, double value) {
    printf("%f", value);
    return os;
}
inline ostream& operator<<(ostream& os, long double value) {
    printf("%Lf", value);
    return os;
}

inline istream& operator>>(istream& os, char& ch){
    ch = getchar();
    return os;
}

inline istream& operator>>(istream& os, char * s){
    int i;
    for (i = 0; i < 255; i++){
        char ch;
        os >> ch;
        if (ch < 32 || ch >= 127) {
            break;
        }
        s[i] = ch;
    }
    s[i] = 0;
    return os;
}

inline istream& operator>>(istream& os, std::string& s){
    char buf[256];
    os >> buf;
    s = string(buf);
    return os;
}


inline istream& operator>>(istream& os, int& i){
    char s[256];
    os >> s;
    i = strtol(s, 0, 10);
    return os;
}

inline istream& operator>>(istream& os, unsigned& i){
    char s[256];
    os >> s;
    i = strtol(s, 0, 10);
    return os;
}

inline istream& operator>>(istream& os, double& d){
    char s[256];
    os >> s;
    d = strtod(s, 0);
    return os;
}

extern istream cin;

} // namespace std

#endif /* _EZCXX_CXX_STREAM */
