template <> _EZCXX_NODISCARD _EZCXX_INLINE constexpr
unsigned char rotl(unsigned char __t, int __r) noexcept {
    constexpr int __n = numeric_limits<unsigned char>::digits;
    __r %= __n;
    return (__r == 0) ? __t : (__r > 0)
        ? ((__t <<  __r) | (__t >> (__n - __r)))
        : ((__t >> -__r) | (__t << (__n + __r)));
}

