	assume	adl=1

	section	.text
	public	_wmemset

_wmemset:
	pop	iy
	pop	hl
	pop	de
	pop	bc
	push	bc
	push	de
	push	hl
	push	iy
	cpi
	add	hl,bc
	ret	c
	add	hl,bc
	ret	c

	dec	hl
	ld	(hl),d	; upper 8 bits
	dec	hl
	ld	(hl),e	; lower 8 bits
	ret	po
	push	hl
	pop	de
	dec	de

	push	bc
	; use lddr twice
	lddr
	pop	bc
	lddr
	ret
