	assume	adl=1

	section	.text

	public	_wmemset

_wmemset:
	pop	iy
	pop	hl
	pop	de
	pop	bc
	push	bc
	push	de
	push	hl
	push	iy
	
	; count *= sizeof(wchar_t)
	cpi	; hl++ bc--
	add	hl, bc
	ret	c	; bc is zero, or overflow
	add	hl, bc
	ret	c	; overflow
	
	; hl += (count - 1) * 2 + 1
	; count -= 2
	ld	(hl), d	; upper 8 bits
	dec	hl
	ld	(hl), e	; lower 8 bits
	inc hl
	ret	po
	push	hl
	pop	de
	dec	de
	dec	de

	push	bc
	; use lddr twice
	lddr
	pop	bc
	lddr
	ret
