	.assume	adl=1

	.section	.text

	.global	_strcmp
	.type	_strcmp, @function

.ifdef PREFER_OS_LIBC

	.set	_strcmp, $0000C8

.else

_strcmp:
	ld	hl, 3
	add	hl, sp
	ld	de, (hl)
	inc	hl
	inc	hl
	inc	hl
	ld	hl, (hl)
.L.loop:
	ld	a, (de)
	cp	a, (hl)
	jr	nz, .L.finish
	inc	hl
	inc	de
	or	a, a
	jr	nz, .L.loop
.L.finish:
	sbc	hl, hl
	ld	l, a
	ret

.endif
